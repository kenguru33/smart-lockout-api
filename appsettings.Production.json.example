{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.HttpsConnectionAdapter": "Warning",
      "SmartLockoutApi": "Information",
      "SmartLockoutApi.Services": "Information",
      "SmartLockoutApi.Tls": "Information"
    },
    "EventLog": {
      "SourceName": "SmartLockoutApi",
      "LogName": "Application"
    }
  },

  "AllowedHosts": "api.example.no",

  "Kestrel": {
    "Certificate": {
      "Subject": "api.example.no",
      "StoreName": "My",
      "StoreLocation": "LocalMachine",
      "RefreshInterval": "00:05:00"
    }
  }
}
